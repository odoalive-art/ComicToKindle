{
  "name": "comic-to-kindle",
  "version": "0.1.0-beta.2",
  "description": "Local comic library, Kindle converter, and delivery tool.",
  "main": "./out/main/index.js",
  "author": "",
  "homepage": "",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release:mac": "npm version prerelease --no-git-tag-version && npm run build:mac"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "7zip-bin": "^5.2.0",
    "archiver": "^8.0.0",
    "nodemailer": "^9.0.1",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/archiver": "^8.0.0",
    "@types/node": "^22.19.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "embla-carousel-react": "^8.6.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "prettier": "^3.7.4",
    "radix-ui": "^1.5.0",
    "react": "^19.2.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "vite": "^7.2.6"
  }
}
